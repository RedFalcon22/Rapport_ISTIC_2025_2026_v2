@startuml etat_support_repli
!theme plain
skinparam stateBorderColor #2C6EA0
skinparam stateBackgroundColor #E8F5E9
skinparam stateArrowColor #2C6EA0
skinparam defaultFontName Arial
skinparam defaultFontSize 11


[*] --> AttenteQuestion : (suite du diagramme 1/2)

AttenteQuestion --> FluxRepli : aucun résultat trouvé

state FluxRepli {
  [*] --> AffichageOptions

  AffichageOptions : Trois options proposées :\nPrendre un rendez-vous\nSignaler un bug\nAccéder au portail support

  AffichageOptions --> FluxRendezVous  : clic "Prendre un rendez-vous"
  AffichageOptions --> FluxSignalement : clic "Signaler un bug"
  AffichageOptions --> PortailExterne  : clic "Portail support"

  state FluxRendezVous {
    [*] --> GenMotif
    GenMotif : Génération automatique\ndu motif depuis l'historique
    GenMotif --> SaisieRDV
    SaisieRDV : Formulaire pré-rempli\n(date, heure, canal)
    SaisieRDV --> EnvoiRDV
    EnvoiRDV : Transmission à NetEthic\n(identité lue depuis la session)
    EnvoiRDV --> [*]
  }

  state FluxSignalement {
    [*] --> GenDescription
    GenDescription : Génération automatique\nde la description depuis l'historique
    GenDescription --> SaisieBug
    SaisieBug : Formulaire pré-rempli\n(description du problème)
    SaisieBug --> EnvoiSignalement
    EnvoiSignalement : Transmission à NetEthic\n(identité lue depuis la session)
    EnvoiSignalement --> [*]
  }

  PortailExterne : Ouverture du portail\nsupport en ligne
  PortailExterne --> [*]
}

FluxRepli --> AttenteQuestion : action terminée

@enduml
