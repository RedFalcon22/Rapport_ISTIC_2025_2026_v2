@startuml sequence_noa
!theme plain
skinparam sequenceArrowColor #2C6EA0
skinparam sequenceLifeLineBorderColor #2C6EA0
skinparam sequenceParticipantBorderColor #2C6EA0
skinparam sequenceParticipantBackgroundColor #EBF4FB
skinparam sequenceActorBorderColor #1A3550
skinparam sequenceGroupBorderColor #888888
skinparam defaultFontName Arial
skinparam defaultFontSize 13

caption Déroulement d'une interaction factuelle typique avec Noa :\npipeline séquentiel (session → réservation → cache → intention → RAG → génération LLM).

actor       "Visiteur"                  as V
participant "Frontend\nReact"           as FE
participant "FastAPI\n(Noa)"            as API
participant "BookingAgent\n(FSM)"       as FSM
participant "Cache FAQ\n(LRU)"          as Cache
participant "ChromaDB\n(embedded)"      as Chroma
participant "Serveur LLM\n(kaisens.fr)" as LLM
participant "Redis\n(sessions)"         as Redis

V  -> FE  : saisit un message
activate FE
FE -> API : POST /api/chat/
activate API

== Étape 1 — Chargement de session ==

API -> Redis : getHistory(session_id)
activate Redis
Redis --> API : historique
deactivate Redis
API -> API : detect_language(message)

== Étape 2 — Interception du flux de réservation ==

API -> FSM : is_in_booking_flow(session_id)
activate FSM
FSM --> API : inactif
deactivate FSM
note right of FSM : Si flux actif → traitement immédiat\nsans appel LLM

== Étape 3 — Vérification du cache FAQ ==

API -> Cache : get(message)
activate Cache
Cache --> API : miss
deactivate Cache
note right of Cache : Si cache HIT → retour direct

== Étape 4 — Classification d'intention ==

API -> LLM : classify_intent(message, historique)
activate LLM
LLM --> API : factual_query
deactivate LLM
note right of LLM : Autres intentions : guardrail,\nbook_demo, chit_chat → retour direct

== Étape 5 — Recherche RAG ==

API -> API : detect_category(message)
API -> Chroma : search(query, filtre_catégorie)
activate Chroma
Chroma --> API : segments pertinents
deactivate Chroma

== Étape 6 — Génération de réponse ==

API -> LLM : generate(system_prompt, rag_context, historique, message)
activate LLM
LLM --> API : réponse brute
deactivate LLM
API -> API : _strip_intro(réponse)

== Étape 7 — Mise en cache et sauvegarde session ==

API -> Cache : set(message, réponse)
API -> Redis : save_history(session_id, historique)
activate Redis
Redis --> API : OK
deactivate Redis

API --> FE : réponse
deactivate API
FE --> V : affiche la réponse
deactivate FE

@enduml
