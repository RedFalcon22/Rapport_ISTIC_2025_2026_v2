@startuml sequence_support_init
!theme plain
skinparam sequenceArrowColor #2C6EA0
skinparam sequenceLifeLineBorderColor #2C6EA0
skinparam sequenceParticipantBorderColor #2C6EA0
skinparam sequenceParticipantBackgroundColor #EBF4FB
skinparam sequenceActorBorderColor #1A3550
skinparam sequenceGroupBorderColor #888888
skinparam defaultFontName Arial
skinparam defaultFontSize 12


actor "Utilisateur interne" as U
participant "Streamlit\nFrontend" as FE
participant "FastAPI" as API
participant "LangChain\n(Chain)" as LC
participant "Serveur LLM\n(kaisens.fr)" as LLM
participant "Redis\n(Session)" as Redis

== Création de session ==

U -> FE : Ouvrir l'assistant()
activate FE

FE -> API : POST /start-session\n{user_id, school_id, username,\nemail, phone, live_data}
activate API

API -> Redis : create_session() + save_session()
activate Redis
Redis --> API : session_id
deactivate Redis

API --> FE : {session_id}
deactivate API

== Soumission de la question ==

opt Filtrage par catégorie (facultatif)
  U -> FE : Sélectionner une catégorie\n(1 parmi 11 modules)
end

U -> FE : Saisir et soumettre la question()

FE -> API : POST /chat\n{session_id, query,\nselected_category (optionnel)}
activate API

== Étape 1 — Garde-fou ==

API -> LC : check_guardrail(query)
activate LC
LC -> LLM : generate(prompt_guardrail + query)
activate LLM
LLM --> LC : {classification: "SAFE"|"UNSAFE", message}
deactivate LLM
LC --> API : {classification, message}
deactivate LC

alt Requête UNSAFE — injection / XSS / haine
  API --> FE : {response: message_rejet,\nguardrail_triggered: true}
  deactivate API
  deactivate FE

else Requête SAFE

  == Étape 2 — Correction orthographique + détection sociale ==

  API -> LC : check_polite(query)
  activate LC
  LC -> LLM : generate(prompt_polite + query)
  activate LLM
  LLM --> LC : {case: "A" ou "B", message, corrected}
  deactivate LLM
  LC --> API : {case, message, corrected}
  deactivate LC

  alt Cas A — Salutation / merci / au revoir
    API -> Redis : save_session() [ajout à l'historique]
    activate Redis
    Redis --> API : OK
    deactivate Redis
    API --> FE : {response: réponse_cordiale,\nguardrail_triggered: false}
    deactivate API
    deactivate FE

  else Cas B — Vraie question (query ← corrected)
    API -> Redis : get_session(session_id)
    activate Redis
    Redis --> API : session (historique, last_chunks, last_category)
    deactivate Redis
    note right of API : Suite dans le\ndiagramme suivant
    deactivate API
    deactivate FE
  end

end

@enduml
