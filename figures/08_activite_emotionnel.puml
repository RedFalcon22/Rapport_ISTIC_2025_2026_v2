@startuml activite_emotionnel
!theme plain
scale 0.8
skinparam activityBorderColor #2C6EA0
skinparam activityBackgroundColor #EBF4FB
skinparam activityArrowColor #2C6EA0
skinparam diamondBorderColor #E65100
skinparam diamondBackgroundColor #FFF3E0
skinparam defaultFontName Arial
skinparam defaultFontSize 12

start

:Valider le message;

:Controle du debit (Redis);

if (Limite depassee ?) then (Oui)
  :Retourner reponse de blocage;
  stop
endif

:Analyser le contenu\nCategories;

if (Categorie ?) then (injection / inapproprie)
  :Retourner refus bienveillant;
  stop
else if (suicidal / violence) then
  :Generer reponse de crise;
  :Ajouter numeros d'urgence;
  stop
else (safe)
endif

:Tampon + extraction profil + persistance;

:Enrichir le prompt avec profil et historique;

:Invoquer le LLM principal;

:Post-traitement + sauvegarde;

:Retourner reponse;

stop

@enduml
