@startuml sequence_classificateur
!theme plain
skinparam sequenceArrowColor #2C6EA0
skinparam sequenceLifeLineBorderColor #2C6EA0
skinparam sequenceParticipantBorderColor #2C6EA0
skinparam sequenceParticipantBackgroundColor #FCE4EC
skinparam sequenceActorBorderColor #1A3550
skinparam sequenceGroupBorderColor #888888
skinparam defaultFontName Arial
skinparam defaultFontSize 13

caption Flux de classification d'un texte — stratégie hybride (LLM avec repli heuristique) :\nquatre stratégies évaluées ; hybrid_fallback retenue pour son meilleur F1-score.

participant "Plateforme\nNetethic" as Plat
participant "Pipeline\nClassificateur" as API
participant "Préprocesseur" as Prep
participant "Client LLM" as CLLM
participant "Heuristiques" as Heur
participant "Serveur LLM\n(kaisens.fr)" as LLM

Plat -> API : texte à classifier
activate API

== Étape 1 — Prétraitement ==

API -> Prep : clean_text(texte)
activate Prep
Prep --> API : texte nettoyé
deactivate Prep
note right of Prep : Suppression URLs / emails,\nnormalisation des espaces,\nmise en minuscules

== Étape 2 — Classification hybride ==

note right of API : Quatre stratégies évaluées :\nheuristic_only, llm/no_rag,\nllm/full_rag, hybrid_fallback.\nLa stratégie hybride est retenue.

API -> CLLM : classify(texte, prompt)
activate CLLM
CLLM -> LLM : inference(prompt, texte_nettoyé)
activate LLM
LLM --> CLLM : labels bruts
deactivate LLM
CLLM --> API : labels normalisés
deactivate CLLM
note right of CLLM : Si LLM indisponible ou réponse\ninvalide → repli automatique\nsur les heuristiques

opt [Repli heuristique]
  API -> Heur : classify_heuristic(texte_nettoyé)
  activate Heur
  Heur --> API : labels
  deactivate Heur
end

== Étape 3 — Journalisation ==

API -> API : save_results(labels, méthode, timestamp)

API --> Plat : labels, méthode, confiance
deactivate API

@enduml
