@startuml sequence_support_rag
!theme plain
skinparam sequenceArrowColor #2C6EA0
skinparam sequenceLifeLineBorderColor #2C6EA0
skinparam sequenceParticipantBorderColor #2C6EA0
skinparam sequenceParticipantBackgroundColor #EBF4FB
skinparam sequenceActorBorderColor #1A3550
skinparam sequenceGroupBorderColor #888888
skinparam defaultFontName Arial
skinparam defaultFontSize 12


actor "Utilisateur interne" as U
participant "Streamlit\nFrontend" as FE
participant "FastAPI" as API
participant "LangChain\n(Chain)" as LC
participant "Serveur LLM\n(kaisens.fr)" as LLM
participant "Redis\n(Session/Cache)" as Redis
participant "ChromaDB" as Chroma

note over U, Chroma
  Suite du flux principal — la session est déjà créée
  et la question a passé le garde-fou (étapes 1 à 2).
end note

activate FE
activate API

== Étapes 3-4 — Classification d'intention + réécriture ==

API -> LC : classify_intent(query)
activate LC
LC -> LLM : generate(prompt_intent + query)
activate LLM
LLM --> LC : "LIVE" ou "PDF"
deactivate LLM
LC --> API : intention
deactivate LC

API -> LC : rewrite_and_detect_followup\n(query, historique)
activate LC
LC -> LLM : generate(prompt_rewrite + query + historique)
activate LLM
LLM --> LC : {rewritten_query, is_followup}
deactivate LLM
LC --> API : {rewritten_query, is_followup}
deactivate LC

== Étape 5 — Cache sémantique (PDF uniquement) ==

alt Intention = PDF
  API -> Redis : get(query)
  activate Redis

  alt Cache HIT
    Redis --> API : réponse_en_cache
    deactivate Redis
    API -> Redis : save_session()
    activate Redis
    Redis --> API : OK
    deactivate Redis
    API --> FE : {response: réponse_en_cache,\nfrom_cache: true, no_results: false}
    deactivate API
    deactivate FE

  else Cache MISS
    Redis --> API : null
    deactivate Redis

    == Étape 7 — Recherche vectorielle filtrée par catégorie ==

    API -> Chroma : search(rewritten_query,\nselected_category, nb_chunks)
    activate Chroma
    Chroma --> API : {chunks_pertinants}
    deactivate Chroma

    alt Aucun chunk au-dessus du seuil (0,35)
      API -> Redis : save_session() [réponse de repli]
      activate Redis
      Redis --> API : OK
      deactivate Redis
      API --> FE : {response: message_repli,\nno_results: true}
      deactivate API
      deactivate FE
    end

  end

else Intention = LIVE
  API --> API : resolve_live_data()\n(depuis session.live_data)
end

== Étape 8 — Génération de réponse ==

API -> LC : chain.invoke(prompt)\n[contexte + historique + question]
activate LC
LC -> LLM : generate(prompt_complet)
activate LLM
LLM --> LC : response_text
deactivate LLM
LC --> API : response_text
deactivate LC

== Étape 9 — Post-traitement ==

API --> API : XSS sanitize (bleach.clean)\n+ détection repli LLM

alt Intention originale = PDF et pas de repli
  API -> Redis : set(query, search_query, résultat)
  activate Redis
  Redis --> API : OK
  deactivate Redis
end

API -> Redis : save_session()\n[historique + chunks + catégorie]
activate Redis
Redis --> API : OK
deactivate Redis

API --> FE : {session_id, response,\nguardrail_triggered: false, no_results: false}
deactivate API
deactivate FE

@enduml
