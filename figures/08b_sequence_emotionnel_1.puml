@startuml sequence_emotionnel_1
!theme plain
skinparam sequenceArrowColor #2C6EA0
skinparam sequenceLifeLineBorderColor #2C6EA0
skinparam sequenceParticipantBorderColor #2C6EA0
skinparam sequenceParticipantBackgroundColor #EBF4FB
skinparam sequenceActorBorderColor #1A3550
skinparam sequenceGroupBorderColor #888888
skinparam defaultFontName Arial
skinparam defaultFontSize 12


actor       "Étudiant"              as U
participant "Streamlit\nFrontend"   as FE
participant "FastAPI\n(api.py)"     as API
participant "LangChain\n(Chain)"    as LC
participant "Redis\n(mémoire)"      as Redis
participant "LLM\nClassificateur"   as CLS
participant "LLM\nPrincipal"        as LLM

U  -> FE  : saisit un message
activate FE
FE -> API : POST /chat (session_id, message, lang)
activate API

== Étape 1 — Validation de la session ==

API -> Redis : vérifier session_id
activate Redis
Redis --> API : {user_id, langue}
deactivate Redis

== Étape 2 — Contrôle du débit ==

API -> Redis : compter les messages récents ()
activate Redis
Redis --> API : compteur actuel
deactivate Redis

== Étape 3 — Analyse par le garde-fou ==

API -> LC : classify(message)
activate LC
LC -> CLS : inference(prompt_classif + message)
activate CLS
CLS --> LC : catégorie brute
deactivate CLS
LC --> API : catégorie\n[safe | injection | inappropriate | suicidal | violence]
deactivate LC

alt Limite dépassée
  note over API : réponse de blocage immédiate\n— étapes suivantes ignorées

else Injection ou contenu inapproprié
  note over API : réponse de refus bienveillant\n(guardrail_triggered: true)

else Idéation suicidaire ou violence
  API -> LC : chain.invoke(prompt_crise, langue)
  activate LC
  LC -> LLM : generate(prompt_crise + langue)
  activate LLM
  LLM --> LC : texte d'accompagnement
  deactivate LLM
  LC --> API : texte d'accompagnement
  deactivate LC
  API -> API : ajouter numéros d'urgence (num)

else Message sûr
  note over API : Suite dans le diagramme suivant\n(étapes 4 → 9)

end

API --> FE : afficher(response, guardrail_triggered, language)
deactivate API
deactivate FE

@enduml
