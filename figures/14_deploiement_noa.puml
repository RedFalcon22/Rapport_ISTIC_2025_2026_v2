@startuml deploiement_noa
!theme plain
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam shadowing false

skinparam node {
  BackgroundColor #EBF4FB
  BorderColor     #1565C0
  BorderThickness 1.5
  FontColor       #0D47A1
  FontSize        11
}
skinparam artifact {
  BackgroundColor #FFFDE7
  BorderColor     #F9A825
  FontColor       #7B5E00
  FontSize        10
}
skinparam component {
  BackgroundColor #F5F5F5
  BorderColor     #78909C
  FontColor       #212121
  FontSize        10
}
skinparam cloud {
  BackgroundColor #ECEFF1
  BorderColor     #546E7A
  FontColor       #263238
}
skinparam arrow {
  Color     #37474F
  Thickness 1.2
  FontSize  10
  FontColor #37474F
}


' ─── CLIENT ────────────────────────────────────────────────
node "Visiteur\n<<device>>" as CLI {
  artifact "Navigateur  :3000" as BR
}

' ─── STACK NOA ─────────────────────────────────────────────
node "Serveur Linux  [Stack Noa]" <<device>> as HOST {
  node "Docker Compose  [bridge]" <<execution environment>> as NET {

    node "netethic-frontend  :3000" <<container>> as FE {
      component "React 18 + Vite\nNginx  (proxy /api → :8000)" as SVC_FE
    }

    node "netethic-backend  :8000" <<container>> as API {
      component "FastAPI  uvicorn\n--reload" as SVC_API
      component "Agent Loop\n[Claude tool-use  /  Gemini]\nsearch_kb · fetch_page\nget_contact · start_booking" as SVC_AGT
      component "Booking FSM\n[booking_agent.py]\nstep-by-step reservation" as SVC_FSM
      component "Intent Router\n[guardrail patterns]" as SVC_GRD
      component "FAQ Cache\n[LRU  in-memory]" as SVC_CACHE
      component "ChromaDB  embedded\ncol: netethic_kb" as SVC_CHR
      artifact "vol  chroma_data\n/app/chroma_db" as VOL_CHR
    }

    node "netethic-redis  (interne)" <<container>> as RED {
      component "Redis 7 Alpine\nSessions  MAX_HISTORY=20" as SVC_RED
      artifact "vol  redis_data" as VOL_RED
    }
  }
}

' ─── LLM EXTERNE ───────────────────────────────────────────
cloud "kaisens.fr  (Production)" as EXT {
  node "GPU Server  [NVIDIA A100]" <<device>> as GPU {
    node "vLLM Runtime" <<execution environment>> {
      component "Mistral-7B-Instruct v0.3\nOpenAI-compat." as LLM_PROD
    }
  }
}

' ─── CONNEXIONS ────────────────────────────────────────────
CLI  --  HOST  : HTTPS  :3000
HOST --  EXT   : HTTPS  :443\nPOST /v1/chat/completions

FE   --> API   : REST /api/chat  /api/health
API  --> RED   : sessions  historique

@enduml
