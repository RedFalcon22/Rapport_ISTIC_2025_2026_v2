@startuml deploiement_global_overview
!theme plain
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam shadowing false

skinparam node {
  BackgroundColor #EBF4FB
  BorderColor     #1565C0
  BorderThickness 1.5
  FontColor       #0D47A1
  FontSize        11
}
skinparam component {
  BackgroundColor #F5F5F5
  BorderColor     #78909C
  FontColor       #212121
  FontSize        10
}
skinparam cloud {
  BackgroundColor #ECEFF1
  BorderColor     #546E7A
  FontColor       #263238
}
skinparam arrow {
  Color     #37474F
  Thickness 1.2
  FontSize  10
  FontColor #37474F
}


' ─── CLIENTS ───────────────────────────────────────────────
node "Visiteur\n<<device>>" as CLI_V
node "Agent interne\n<<device>>" as CLI_A
node "Etudiant\n<<device>>" as CLI_S
node "NetEthic\n<<system>>" as CLI_P

' ─── STACK 1 : NOA ─────────────────────────────────────────
node "Stack Noa  [Module 1]\nServeur Linux  :3000" <<device>> as NOA {
  node "Docker Compose  [bridge]" <<execution environment>> as DC_NOA {
    component "React/Nginx  +  FastAPI\nChromaDB embedded\nRedis  Agent Claude" as C_NOA
  }
}

' ─── STACK 2 : SUPPORT ─────────────────────────────────────
node "Stack Support  [Module 2]\nServeur Linux  :8501" <<device>> as SUP {
  node "Docker Compose  [bridge]" <<execution environment>> as DC_SUP {
    component "Streamlit  +  FastAPI\nChromaDB embedded\nRedis  RAG 10 etapes" as C_SUP
  }
}

' ─── STACK 3 : EMOTIONNEL ──────────────────────────────────
node "Stack Emotionnel  [Module 3]\nServeur Linux  :8501" <<device>> as EMO {
  node "Docker Compose  [bridge]" <<execution environment>> as DC_EMO {
    component "Streamlit  +  FastAPI\nRedis TTL 30j\n3 profils LLM" as C_EMO
  }
}

' ─── STACK 4 : CLASSIFICATEUR ──────────────────────────────
node "Stack Classificateur  [Module 4]\nServeur Linux" <<device>> as CLS {
  node "Docker Compose  [bridge]" <<execution environment>> as DC_CLS {
    component "Scala/Spark  4 strategies\nChromaDB :8000\nembed-server :5001" as C_CLS
  }
}

' ─── LLM EXTERNE ───────────────────────────────────────────
cloud "kaisens.fr\n(vLLM partage — 4 modules)" as EXT_KAI {
  component "vLLM  Mistral-7B-Instruct v0.3\nGPU A100  OpenAI-compat." as LLM_KAI
}

' ─── CONNEXIONS CLIENTS ─────────────────────────────────────
CLI_V --> NOA : HTTPS  :3000
CLI_A --> SUP : HTTPS  :8501
CLI_S --> EMO : HTTPS  :8501
CLI_P --> CLS : batch  JSONL

' ─── CONNEXIONS LLM ─────────────────────────────────────────
NOA --> EXT_KAI : POST /v1/chat/completions
SUP --> EXT_KAI : POST /v1/chat/completions
EMO --> EXT_KAI : POST /v1/chat/completions
CLS --> EXT_KAI : POST /v1/chat/completions

@enduml
