@startuml sequence_support_repli
!theme plain
skinparam sequenceArrowColor #2C6EA0
skinparam sequenceLifeLineBorderColor #2C6EA0
skinparam sequenceParticipantBorderColor #2C6EA0
skinparam sequenceParticipantBackgroundColor #EBF4FB
skinparam sequenceActorBorderColor #1A3550
skinparam sequenceGroupBorderColor #888888
skinparam defaultFontName Arial
skinparam defaultFontSize 12


actor "Utilisateur interne" as U
participant "Streamlit\nFrontend" as FE
participant "FastAPI" as API
participant "LangChain\n(Chain)" as LC
participant "Serveur LLM\n(kaisens.fr)" as LLM
participant "Redis\n(Session)" as Redis
participant "API\nNetEthic" as NetEthic

note over U, NetEthic
  Ce flux est déclenché lorsque no_results=true :
  aucun document pertinent trouvé dans ChromaDB.
  Le frontend affiche trois boutons de repli.
end note

== Option A — Prise de rendez-vous ==

U -> FE : Cliquer "Prendre un rendez-vous"
activate FE

FE -> API : POST /generate-description\n{session_id, mode: "motif"}
activate API

API -> Redis : get_session(session_id)
activate Redis
Redis --> API : session (historique de conversation)
deactivate Redis

API -> LC : generate_description(session, motif)
activate LC
LC -> LLM : generate(prompt_motif + historique)
activate LLM
LLM --> LC : motif_auto (1-2 phrases)
deactivate LLM
LC --> API : motif_auto
deactivate LC

API --> FE : {description: motif_auto}
deactivate API

U -> FE : Vérifier et valider le formulaire RDV

FE -> API : POST /appointments\n{session_id, date, heure, canal}
activate API

API -> Redis : get_session(session_id)
activate Redis
Redis --> API : {username, email, phone}
deactivate Redis

API -> NetEthic : POST makeAppointment\n{username, email, phone,\nmotif, date, heure, canal}
activate NetEthic
NetEthic --> API : {success: true}
deactivate NetEthic

API --> FE : {success: true}
deactivate API
deactivate FE

== Option B — Signalement de bug ==

U -> FE : Cliquer "Signaler un bug"
activate FE

FE -> API : POST /generate-description\n{session_id, mode: "bug_report"}
activate API

API -> Redis : get_session(session_id)
activate Redis
Redis --> API : session (historique de conversation)
deactivate Redis

API -> LC : generate_description(session, bug_report)
activate LC
LC -> LLM : generate(prompt_bug , historique)
activate LLM
LLM --> LC : description_bug ()
deactivate LLM
LC --> API : description_bug
deactivate LC

API --> FE : {description: description_bug}
deactivate API

U -> FE : Vérifier et valider le formulaire()

FE -> API : POST /bug-reports\n{session_id, description}
activate API

API -> Redis : get_session(session_id)
activate Redis
Redis --> API : {username, email, phone}
deactivate Redis

API -> NetEthic : POST signalBug\n{username, email, phone,\ndescription}
activate NetEthic
NetEthic --> API : {success: true}
deactivate NetEthic

API --> FE : {success: true}
deactivate API
deactivate FE

@enduml
