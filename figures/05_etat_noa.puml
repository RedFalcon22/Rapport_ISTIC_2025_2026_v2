@startuml etat_noa
!theme plain
skinparam stateBorderColor #2C6EA0
skinparam stateBackgroundColor #EBF4FB
skinparam stateArrowColor #2C6EA0
skinparam defaultFontName Arial
skinparam defaultFontSize 13


[*] --> Inactif : démarrage du service

' ─────────────────────────────────────────────────────────
' Étape 1 — Interception du flux de réservation
' ─────────────────────────────────────────────────────────
Inactif --> InterceptionReservation : message reçu

InterceptionReservation --> GestionReservation : flux de réservation actif\n(BookingAgent en cours)
InterceptionReservation --> VerificationGuardrail : aucun flux actif

' ─────────────────────────────────────────────────────────
' Flux de réservation (automate FSM, 6 étapes)
' ─────────────────────────────────────────────────────────
state "GestionReservation\n(automate FSM)" as GestionReservation {
  [*]           --> CollecteDate       : démarrage réservation
  CollecteDate     --> CollecteHoraire    : date sélectionnée (puces Calendly)
  CollecteHoraire  --> CollecteNom        : horaire sélectionné
  CollecteNom      --> CollecteEmail      : nom complet fourni
  CollecteEmail    --> CollecteTelephone  : e-mail validé
  CollecteTelephone --> [*]              : téléphone fourni → lien Calendly généré
}

GestionReservation --> Inactif : confirmation envoyée\n+ lien Calendly profond

' ─────────────────────────────────────────────────────────
' Étape 2 — Vérification du garde-fou
' ─────────────────────────────────────────────────────────
VerificationGuardrail --> MessageBloque    : jailbreak / contenu adulte / hors-sujet
VerificationGuardrail --> VerificationCache : message autorisé

MessageBloque --> Inactif : refus poli envoyé

' ─────────────────────────────────────────────────────────
' Étape 3 — Cache FAQ (LRU in-memory)
' ─────────────────────────────────────────────────────────
VerificationCache --> Inactif     : cache hit\nréponse < 1 ms
VerificationCache --> BoucleAgent : cache miss

' ─────────────────────────────────────────────────────────
' Étape 4 — Boucle agent tool-use
' ─────────────────────────────────────────────────────────
state "BoucleAgent\n(max 5 itérations)" as BoucleAgent {
  [*]          --> ChoixOutil
  ChoixOutil   --> RechercheDocs    : search_knowledge_base
  ChoixOutil   --> ScrapingPage     : fetch_website_page
  ChoixOutil   --> InfoContact      : get_contact_info
  ChoixOutil   --> DemarrageReserv  : start_booking_demo
  RechercheDocs --> ChoixOutil : chunks retournés
  ScrapingPage  --> ChoixOutil : contenu page
  InfoContact   --> ChoixOutil : coordonnées
  DemarrageReserv --> [*] : FSM activé
  ChoixOutil   --> [*] : réponse finale générée
}

BoucleAgent --> MiseAJourCache   : réponse générée
DemarrageReserv --> GestionReservation : FSM activé depuis l'agent

' ─────────────────────────────────────────────────────────
' Étape 5 — Cache write + session
' ─────────────────────────────────────────────────────────
MiseAJourCache   --> MiseAJourSession : entrée LRU écrite (TTL 24 h)
MiseAJourSession --> Inactif          : session Redis mise à jour

@enduml
