@startuml activite_classificateur
!theme plain
skinparam activityBorderColor #2C6EA0
skinparam activityBackgroundColor #FCE4EC
skinparam activityArrowColor #2C6EA0
skinparam diamondBorderColor #880000
skinparam diamondBackgroundColor #FCE4EC
skinparam defaultFontName Arial
skinparam defaultFontSize 11

caption Chaîne de repli du classificateur de harcèlement :\nstratégie hybride — tentative LLM puis repli automatique sur les heuristiques en cas d'échec.

start

:Réception du texte;

:Prétraitement\n(URLs, espaces, minuscules);

:Appel LLM\n(prompt + texte prétraité);

if (LLM répond correctement ?) then (Oui)

  :labels ← résultat LLM;

  :Vérification urgence\n(Suicide / Self Harm → urgent);

else (Non — échec ou réponse invalide)

  :Repli — Heuristiques par mots-clés;

  if (Score de harcèlement > seuil ?) then (Oui)
    :labels ← HARASSMENT;
  else (Non)
    :labels ← NOT_HARASSMENT;
  endif

endif

:Journalisation\n(labels, méthode, confiance, timestamp);

:Retour à la plateforme\n(labels, méthode, confiance);

stop

@enduml
